# cp .env.example .env  →  điền giá trị thật vào .env
# KHÔNG commit .env lên git
# CI (GitLab): set các biến này trong Settings → CI/CD → Variables

# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=Flutter_Dev
BUNDLE_ID=flutter.dev
APPLICATION_ID=flutter.dev
URL_SCHEME=flutter
URL_SCHEME_UAT=flutter

# ── API ────────────────────────────────────────────────────────────────────────
API_URL=https://flutter-dev.vn

# ── Google ─────────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AI123abc
GOOGLE_CLIENT_ID=123abc.apps.googleusercontent.com
GOOGLE_REVERSED_CLIENT_ID=com.googleusercontent.apps.123abc

# ── Facebook ───────────────────────────────────────────────────────────────────
FACEBOOK_APP_ID=123456
FACEBOOK_CLIENT_TOKEN=bddca123456

# ── Transistorsoft Background Geolocation ──────────────────────────────────────
BG_GEOLOCATION_LICENSE=eyJhbGciOiJFZERTQ123...
